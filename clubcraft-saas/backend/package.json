    "@fastify/webhook": "^3.0.0",
    "@prisma/client": "^5.9.1",
    "dotenv": "^16.3.1",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "fastify-swagger": "^8.11.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "p-retry": "^6.0.1",
    "stripe": "^14.22.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.25",
    "@types/supertest": "^2.0.16",
    "eslint": "^8.56.0",
    "eslint-config-standard-with-typescript": "^39.1.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "prisma": "^5.9.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
